# ==================== LLM 基础配置 ====================
# 必填：用于对话解析、病历生成、质控等能力
OPENAI_API_KEY=your-openai-api-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-3.5-turbo
TEMPERATURE=0.7

# ==================== 检索配置 ====================
RETRIEVAL_MODE=simple
# 可留空，默认复用 OPENAI_BASE_URL
EMBEDDING_BASE_URL=
EMBEDDING_MODEL=text-embedding-ada-002
LLAMAGRAPH_PERSIST_DIR=./storage/llamagraph
LLAMAINDEX_PERSIST_DIR=./storage/llamaindex
LLAMAINDEX_COLLECTION_NAME=medical_guidelines
LLAMAINDEX_CHUNK_SIZE=512
LLAMAINDEX_CHUNK_OVERLAP=50
GRAPH_STORE_MODE=memory
CHROMA_PERSIST_DIR=./data/chroma_db
GUIDELINES_PATH=./data/guidelines/clinical_guidelines.json

# ==================== API / Frontend ====================
API_HOST=0.0.0.0
API_PORT=8888
API_RELOAD=true
API_URL=http://localhost:8888
REQUEST_TIMEOUT=120
FRONTEND_URL=http://localhost:8501

# ==================== 语音识别（可选） ====================
# 推荐使用官方环境变量名 DASHSCOPE_API_KEY。
# 如果你已有兼容配置，也可以改用 ASR_API_KEY；两者任选其一，不需要同时设置。
DASHSCOPE_API_KEY=your-dashscope-api-key
# ASR_API_KEY=your-dashscope-api-key
ASR_REGION=singapore
ASR_LANGUAGE=zh
ASR_SAMPLE_RATE=16000
ASR_MODEL=qwen3-asr-flash-realtime
ASR_FILE_MODEL=qwen3-asr-flash
ASR_TIMEOUT_SECONDS=20
ENABLE_MEDICAL_TERMS=true

# ==================== 应用通用配置 ====================
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log
MAX_CONVERSATION_TURNS=10
MAX_REVISION_ITERATIONS=3
